# Application authentication
AZURE_TENANT_ID=4e99b5ff-dd77-418a-8b69-1d684e911168
AZURE_CLIENT_ID=653f4fbf-ba11-406c-98ea-e61d637d79d0
AZURE_CLIENT_SECRET=replace-with-a-new-secret

# Optional static delegated token; overrides application authentication
