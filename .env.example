GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
HOST=0.0.0.0
PORT=8000
MCP_TRANSPORT=streamable-http
REQUEST_TIMEOUT_SECONDS=120
VERIFY_SSL=true
MAX_SIMPLE_UPLOAD_MB=200
UPLOAD_CHUNK_SIZE=10485760

